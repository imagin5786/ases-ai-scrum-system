{
  "model": "claude-sonnet-4-5-20251101",
  "maxTokens": 8096,
  "permissions": {
    "allowedTools": [
      "Read", "Write", "View",
      "Bash(git add:*)", "Bash(git status:*)", "Bash(git commit:*)",
      "Bash(git diff:*)", "Bash(git log:*)", "Bash(git branch:*)",
      "Bash(mkdir:*)", "Bash(ls:*)", "Bash(cat:*)", "Bash(find:*)",
      "Bash(cp:*)", "Bash(mv:*)", "Bash(python3:*)",
      "Bash(pytest:*)", "Bash(npm:*)", "Bash(node:*)"
    ],
    "deny": [
      "Write(./.env)",
      "Write(./.env.*)",
      "Write(./production.config.*)",
      "Bash(rm -rf:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/ases-hook.py"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/ases-hook.py"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/ases-hook.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write(.ases/context.json)",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[ASES] Context updated: $(date)\" >> .ases/.audit.log"
          }
        ]
      },
      {
        "matcher": "Write(sprints/*/execution/snapshots/*.json)",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[ASES] Snapshot saved: $CLAUDE_TOOL_FILE $(date)\" >> .ases/.audit.log"
          }
        ]
      }
    ]
  }
}
